[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Operation = Remove
Target = *

[Action]
Description = Create backup list of packages installed (including AUR)
When = PreTransaction
Exec = /bin/sh -c 'pacman -Qqen > "/home/ernesto/.config/pacman/pkglist.txt"; pacman -Qqem >> "/home/ernesto/.config/pacman/pkglist_auxiliares.txt" 2> /dev/null; exit'
