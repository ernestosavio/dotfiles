theme = /home/ernesto/.config/ghostty/themes/ashen
shell-integration = none
gtk-titlebar = false
quick-terminal-animation-duration = 0
custom-shader-animation = false
quit-after-last-window-closed = true
wait-after-command = false
confirm-close-surface = false
background-opacity = 0.96
font-size = 14

# JetBrain Mono
font-family = "JetBrains Mono NL"

font-feature = -calt
font-feature = +liga
font-feature = +dlig

adjust-cell-width="3.5%"

# Hack
#font-family = "Hack JBM Ligatured"

# MonaspaceNeon Variable
#font-family = "Monaspace Neon Var"

# Habilitar características OpenType para texture healing y ligaduras
#font-feature = +calt
#font-feature = +liga
#font-feature = +dlig
#font-feature = -ss01
#font-feature = +ss02
#font-feature = -ss03
#font-feature = +ss04
#font-feature = +ss05
#font-feature = -ss06
#font-feature = +ss07
#font-feature = +ss08
